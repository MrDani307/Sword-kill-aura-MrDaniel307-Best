-- // ФУНКЦИЯ УВЕДОМЛЕНИЙ (Dynamic Island)
local function notify(text, color)
    local notif = Instance.new("Frame", sg)
    notif.Size = UDim2.new(0, 200, 0, 40)
    notif.Position = UDim2.new(0.5, -100, 0, -50)
    notif.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    notif.BackgroundTransparency = 0.2
    Instance.new("UICorner", notif).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", notif).Color = color
    
    local lab = Instance.new("TextLabel", notif)
    lab.Size = UDim2.new(1, 0, 1, 0)
    lab.BackgroundTransparency = 1
    lab.Text = text
    lab.TextColor3 = Color3.new(1,1,1)
    lab.Font = Enum.Font.GothamMedium
    lab.TextSize = 14
    
    notif:TweenPosition(UDim2.new(0.5, -100, 0, 50), "Out", "Back", 0.5)
    task.delay(2, function()
        notif:TweenPosition(UDim2.new(0.5, -100, 0, -50), "In", "Sine", 0.5)
        task.wait(0.5)
        notif:Destroy()
    end)
end

-- // ПЛАВНОЕ ПЕРЕТАСКИВАНИЕ (Custom Drag)
local function makeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

