-- Вспомогательная функция для кнопок с неоновым свечением
local function createNeonButton(parent, layoutOrder, text, iconAsset)
	local btn = Instance.new("TextButton", parent)
	btn.Size = UDim2.new(1, 0, 0, 65)
	btn.BackgroundColor3 = THEME.OffColor
	btn.Text = ""
	btn.AutoButtonColor = false
	btn.LayoutOrder = layoutOrder
	btn.ZIndex = 6
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 18)

	-- Внутренняя тень/свечение (Создает объем)
	local glowStroke = Instance.new("UIStroke", btn)
	glowStroke.Thickness = 2
	glowStroke.Color = THEME.MainText
	glowStroke.Transparency = 0.8

	-- Тень под кнопкой
	createShadow(btn, UDim2.new(1, 15, 1, 15))

	local icon = Instance.new("ImageLabel", btn)
	icon.Size = UDim2.new(0, 28, 0, 28)
	icon.Position = UDim2.new(0, 20, 0.5, -14)
	icon.BackgroundTransparency = 1
	icon.Image = iconAsset
	icon.ImageColor3 = THEME.MainText

	local txt = Instance.new("TextLabel", btn)
	txt.Size = UDim2.new(1, -70, 1, 0)
	txt.Position = UDim2.new(0, 60, 0, 0)
	txt.BackgroundTransparency = 1
	txt.Text = text
	txt.TextColor3 = THEME.MainText
	txt.Font = Enum.Font.GothamMedium
	txt.TextSize = 16
	txt.TextXAlignment = Enum.TextXAlignment.Left

	return btn, txt, glowStroke
end

