-- Вспомогательная функция для теней
local function createShadow(parent, size, cornerRadius)
	local shadow = Instance.new("ImageLabel", parent)
	shadow.Size = size
	shadow.Position = UDim2.new(0.5, 0, 0.5, 0)
	shadow.AnchorPoint = Vector2.new(0.5, 0.5)
	shadow.BackgroundTransparency = 1
	shadow.Image = SHADOW_IMAGE
	shadow.ImageColor3 = THEME.SoftShadow
	shadow.ImageTransparency = 0.6 -- Мягче
	shadow.ZIndex = parent.ZIndex - 1 -- Под родителя
	shadow.ScaleType = Enum.ScaleType.Slice
	shadow.SliceCenter = Rect.new(10, 10, 118, 118)
	return shadow
end

