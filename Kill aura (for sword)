-- // АНИМАЦИИ
local isOpen = false
openBtn.MouseButton1Click:Connect(function()
	isOpen = not isOpen
	if isOpen then
		main.Visible = true
		main:TweenSizeAndPosition(UDim2.new(0, 220, 0, 180), UDim2.new(0.5, -110, 0.5, -90), "Out", "Back", 0.4, true)
	else
		main:TweenSizeAndPosition(UDim2.new(0, 0, 0, 0), UDim2.new(0.5, 0, 0.5, 0), "In", "Sine", 0.2, true, function()
			if not isOpen then main.Visible = false end
		end)
	end
end)

-- // ЛОГИКА
local active = false
local range = 5
local visualSphere = nil
local highlights = {}

toggle.MouseButton1Click:Connect(function()
	active = not active
	local targetCol = active and Color3.fromRGB(52, 199, 89) or Color3.fromRGB(255, 59, 48)
	TweenService:Create(toggle, TweenInfo.new(0.25), {BackgroundColor3 = targetCol}):Play()
	toggle.Text = active and "Aura: Active" or "Aura: Off"

	if not active then
		if visualSphere then visualSphere:Destroy() visualSphere = nil end
		for _, h in pairs(highlights) do h:Destroy() end
		highlights = {}
	end
end)

box.FocusLost:Connect(function()
	range = tonumber(box.Text) or 5
	box.Text = tostring(range)
end)

-- // ТОТ САМЫЙ ЦИКЛ РЕГИСТРАЦИИ (1 в 1)
local hue = 0
RunService.Heartbeat:Connect(function(dt)
	if not active then return end
	hue = (hue + dt * 0.4) % 1
	local color = Color3.fromHSV(hue, 0.8, 1)

	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local tool = char and char:FindFirstChildOfClass("Tool")
	local handle = tool and (tool:FindFirstChild("Handle") or tool:FindFirstChildOfClass("Part") or tool:FindFirstChildOfClass("MeshPart"))

	if hrp and handle then
		-- Сфера
		if not visualSphere then
			visualSphere = Instance.new("Part", workspace)
			visualSphere.Shape = "Ball"
			visualSphere.Material = "ForceField"
			visualSphere.CastShadow = false
			visualSphere.CanCollide = false
			visualSphere.CanTouch = false
			visualSphere.Anchored = true
			visualSphere.Transparency = 0.5
		end
		visualSphere.Size = Vector3.new(range*2, range*2, range*2)
		visualSphere.Color = color
		visualSphere.CFrame = handle.CFrame

		local currentTargets = {}
		for _, v in ipairs(Players:GetPlayers()) do
			if v ~= player and v.Character and (v.Team ~= player.Team or v.Team == nil) then
				local tChar = v.Character
				local tHrp = tChar:FindFirstChild("HumanoidRootPart")
				local tHum = tChar:FindFirstChild("Humanoid")

				if tHrp and tHum and tHum.Health > 0 then
					local dist = (hrp.Position - tHrp.Position).Magnitude
					if dist <= range then
						currentTargets[v.Name] = tChar
						
						-- Highlight
						if not highlights[v.Name] then
							local h = Instance.new("Highlight", tChar)
							h.FillTransparency = 0.5
							highlights[v.Name] = h
						end
						highlights[v.Name].FillColor = color
						highlights[v.Name].OutlineColor = color

						-- РЕГИСТРАЦИЯ УРОНА (КАК В ОРИГИНАЛЕ)
						tool:Activate()
						for _, part in ipairs(tChar:GetChildren()) do
							if part:IsA("BasePart") then
								firetouchinterest(handle, part, 0)
								firetouchinterest(handle, part, 1)
							end
						end
					end
				end
			end
		end

		for name, h in pairs(highlights) do
			if not currentTargets[name] then h:Destroy() highlights[name] = nil end
		end
	else
		if visualSphere then visualSphere:Destroy() visualSphere = nil end
	end
end)
