local active = false
local range = 5
local visualSphere = nil
local highlights = {}

-- Переменные для автоэкипировки меча
local swordEquipped = false
local swordName = "Sword" -- название меча в инвентаре (если нужно изменить, поменяй здесь)

-- Функция экипировки меча (перенос из Backpack в Character)
local function equipSword()
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return false end
    local sword = backpack:FindFirstChild(swordName)
    if sword and sword:IsA("Tool") then
        local char = player.Character
        if char then
            sword.Parent = char
            return true
        end
    end
    return false
end

-- Функция деэкипировки меча (перенос из Character обратно в Backpack)
local function unequipSword()
    local char = player.Character
    if not char then return false end
    local sword = char:FindFirstChild(swordName)
    if sword and sword:IsA("Tool") then
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            sword.Parent = backpack
            return true
        end
    end
    return false
end

toggle.MouseButton1Click:Connect(function()
	active = not active
	local targetCol = active and THEME.On or THEME.Off
	TweenService:Create(toggle, TweenInfo.new(0.3), {BackgroundColor3 = targetCol}):Play()
	toggle.Text = active and "STATUS: ACTIVE" or "STATUS: OFF"
	
	if not active then
		if visualSphere then visualSphere:Destroy() visualSphere = nil end
		for _, h in pairs(highlights) do h:Destroy() end
		highlights = {}
		-- Если killaura выключена, возвращаем меч в инвентарь
		if swordEquipped then
			unequipSword()
			swordEquipped = false
		end
	end
end)

