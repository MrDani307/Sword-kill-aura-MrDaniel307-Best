            visualSphere.CastShadow = false
            visualSphere.CanCollide = false
            visualSphere.CanTouch = false
            visualSphere.Anchored = true
            visualSphere.Transparency = 0.5
        end
        visualSphere.Size = Vector3.new(range*2, range*2, range*2)
        visualSphere.Color = rainbowColor
        visualSphere.CFrame = handle.CFrame
        
        -- Атака
        local currentFrame = {}
        for _, v in ipairs(Players:GetPlayers()) do
            if v ~= player and v.Character and (v.Team ~= player.Team or v.Team == nil) then
                local tHrp = v.Character:FindFirstChild("HumanoidRootPart")
                local tHum = v.Character:FindFirstChild("Humanoid")
                
                if tHrp and tHum and tHum.Health > 0 then
                    local dist = (char.HumanoidRootPart.Position - tHrp.Position).Magnitude
                    if dist <= range then
                        currentFrame[v.Name] = v.Character
                        
                        -- Highlight
                        if not highlights[v.Name] then
                            local h = Instance.new("Highlight", v.Character)
                            h.FillTransparency = 0.5
                            highlights[v.Name] = h
                        end
                        highlights[v.Name].FillColor = rainbowColor
                        highlights[v.Name].OutlineColor = rainbowColor
                        
                        -- Ультра-атака (Fire!)
                        tool:Activate()
                        for i = 1, 5 do -- Увеличил до 5 для максимального урона
                            firetouchinterest(handle, tHrp, 0)
                            firetouchinterest(handle, tHrp, 1)
                        end
                    end
                end
            end
        end
        
        -- Очистка
        for name, h in pairs(highlights) do
            if not currentFrame[name] then
                h:Destroy()
                highlights[name] = nil
            end
        end
    else
        if visualSphere then visualSphere:Destroy() visualSphere = nil end
    end
end)
