-- // АНИМАЦИИ ОТКРЫТИЯ/ЗАКРЫТИЯ (Fluid Scale)
local isOpen = false
local MAIN_SIZE = UDim2.new(0, 280, 0, 230) -- Финальный размер
local MAIN_POS = UDim2.new(0.5, -140, 0.5, -115)

openBtn.MouseButton1Click:Connect(function()
	isOpen = not isOpen
	
	-- Анимация клика по иконке
	TweenService:Create(innerOpen, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Rotation = isOpen and 90 or 0, ImageTransparency = isOpen and 0 or 0.2}):Play()

	if isOpen then
		main.Visible = true
		-- Скейл из центра
		main.Size = UDim2.new(0, 0, 0, 0)
		main.Position = UDim2.new(0.5, 0, 0.5, 0)
		main.GroupTransparency = 1

		TweenService:Create(main, TweenInfo.new(0.6, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
			Size = MAIN_SIZE,
			Position = MAIN_POS,
			GroupTransparency = 0
		}):Play()
	else
		-- Схлопывание
		TweenService:Create(main, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.new(0.5, 0, 0.5, 0),
			GroupTransparency = 1
		}):Play()
		task.wait(0.4)
		if not isOpen then main.Visible = false end
	end
end)

-- // ЛОГИКА АУРЫ (Твоя оригинальная, в новом Визуале)
local active = false
local range = 5
local visualSphere = nil
local highlights = {}

toggleBtn.MouseButton1Click:Connect(function()
	active = not active
	local targetCol = active and STYLES.AccentOn or STYLES.AccentOff
	local targetText = active and "SYSTEM ACTIVE" or "SYSTEM DISABLED"
	
	-- Эффект нажатия
	TweenService:Create(toggleBtn, TweenInfo.new(0.1, Enum.EasingStyle.Cubic), {Size = UDim2.new(1, -10, 0, 55)}):Play()
	task.wait(0.05)
	TweenService:Create(toggleBtn, TweenInfo.new(0.3, Enum.EasingStyle.Elastic), {Size = UDim2.new(1, 0, 0, 60)}):Play()

	-- Плавная смена цвета и текста
	TweenService:Create(toggleBtn, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {BackgroundColor3 = targetCol}):Play()
	togText.Text = targetText

	if not active then
		if visualSphere then visualSphere:Destroy() visualSphere = nil end
		for _, h in pairs(highlights) do h:Destroy() end
		highlights = {}
	end
end)

box.FocusLost:Connect(function()
	-- Улучшенная фильтрация ввода
	local val = tonumber(box.Text:match("%d+%.?%d*")) or 5
	val = math.clamp(val, 0.1, 100) -- Ограничим от 0.1 до 100 studs
	range = val
	box.Text = string.format("%.1f", range)
end)

-- Основной цикл (Регистрация урона не менялась)
local hue = 0
RunService.Heartbeat:Connect(function(dt)
	if not active then return end
	hue = (hue + dt * 0.4) % 1
	local color = Color3.fromHSV(hue, 0.7, 1)

	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local tool = char and char:FindFirstChildOfClass("Tool")
	local handle = tool and (tool:FindFirstChild("Handle") or tool:FindFirstChildOfClass("Part") or tool:FindFirstChildOfClass("MeshPart"))

	if hrp and handle then
		if not visualSphere then
			visualSphere = Instance.new("Part", workspace)
			visualSphere.Shape = "Ball"
			visualSphere.Material = "ForceField"
			visualSphere.CastShadow = false
			visualSphere.CanCollide = false
			visualSphere.CanTouch = false
			visualSphere.Anchored = true
			visualSphere.Transparency = 0.7 -- Чуть прозрачнее
		end
		visualSphere.Size = Vector3.new(range*2, range*2, range*2)
		visualSphere.Color = color
		visualSphere.CFrame = handle.CFrame

		local currentTargets = {}
		for _, v in ipairs(Players:GetPlayers()) do
			if v ~= player and v.Character and (v.Team ~= player.Team or v.Team == nil) then
				local tChar = v.Character
				local tHrp = tChar:FindFirstChild("HumanoidRootPart")
				local tHum = tChar:FindFirstChild("Humanoid")

				if tHrp and tHum and tHum.Health > 0 then
					local dist = (hrp.Position - tHrp.Position).Magnitude
					if dist <= range then
						currentTargets[v.Name] = tChar
						
						if not highlights[v.Name] then
							local h = Instance.new("Highlight", tChar)
							h.FillTransparency = 0.6
							h.OutlineTransparency = 0.1 -- Яркий контур
							highlights[v.Name] = h
						end
						highlights[v.Name].FillColor = color
						highlights[v.Name].OutlineColor = Color3.new(1,1,1)

						-- ТВОЙ ОРИГИНАЛЬНЫЙ УРОН
						tool:Activate()
						for _, part in ipairs(tChar:GetChildren()) do
							if part:IsA("BasePart") then
								firetouchinterest(handle, part, 0)
								firetouchinterest(handle, part, 1)
							end
						end
					end
				end
			end
		end

		for name, h in pairs(highlights) do
			if not currentTargets[name] then h:Destroy() highlights[name] = nil end
		end
	else
		if visualSphere then visualSphere:Destroy() visualSphere = nil end
	end
end)
