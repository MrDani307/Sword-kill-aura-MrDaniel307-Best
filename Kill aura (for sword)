-- // 3. "ЖИДКАЯ" АНИМАЦИЯ ОТКРЫТИЯ (Spring Physics)
local isOpen = false
local tweenIn = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local tweenOut = TweenInfo.new(0.25, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)

openBtn.MouseButton1Click:Connect(function()
    isOpen = not isOpen
    if isOpen then
        main.Visible = true
        main.Size = UDim2.new(0, 50, 0, 50)
        main.Position = UDim2.new(0.5, -25, 0.5, -25)
        
        TweenService:Create(main, tweenIn, {
            Size = UDim2.new(0, 220, 0, 180),
            Position = UDim2.new(0.5, -110, 0.5, -90)
        }):Play()
    else
        local shrink = TweenService:Create(main, tweenOut, {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0)
        })
        shrink:Play()
        shrink.Completed:Connect(function() if not isOpen then main.Visible = false end end)
    end
end)

-- // ПЕРЕМЕННЫЕ ЛОГИКИ
local active = false
local range = 5
local visualSphere = nil
local highlights = {}

toggle.MouseButton1Click:Connect(function()
    active = not active
    local targetColor = active and Color3.fromRGB(52, 199, 89) or Color3.fromRGB(255, 59, 48) -- Apple Green / Red
    TweenService:Create(toggle, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
    
    toggle.Text = active and "Aura: Active" or "Aura: Off"

    if not active then
        if visualSphere then visualSphere:Destroy() visualSphere = nil end
        for _, h in pairs(highlights) do h:Destroy() end
        highlights = {}
    end
end)

box.FocusLost:Connect(function()
    range = tonumber(box.Text) or 5
    box.Text = tostring(range)
end)

-- // ГЛАВНЫЙ ЦИКЛ (ИСПРАВЛЕНА РЕГИСТРАЦИЯ УРОНА)
local hue = 0
