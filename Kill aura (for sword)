-- // АНИМАЦИИ
local function animateUI(visible)
    if visible then
        main.Size = UDim2.new(0, 0, 0, 0)
        main.Visible = true
        main:TweenSize(UDim2.new(0, 240, 0, 200), "Out", "Back", 0.4, true)
    else
        main:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Back", 0.3, true, function()
            main.Visible = false
        end)
    end
end

openBtn.MouseButton1Click:Connect(function()
    animateUI(not main.Visible)
end)

-- // ПЕРЕМЕННЫЕ ЛОГИКИ
local active = false
local range = 15
local visualSphere = nil
local highlights = {}

toggle.MouseButton1Click:Connect(function()
    active = not active
    local targetColor = active and Color3.fromRGB(0, 255, 120) or Color3.fromRGB(255, 0, 60)
    
    -- Плавная смена цвета кнопки
    TweenService:Create(tStroke, TweenInfo.new(0.3), {Color = targetColor}):Play()
    toggle.Text = active and "AURA IS ACTIVE" or "AURA IS OFF"
    toggle.TextColor3 = targetColor

    if not active then
        if visualSphere then visualSphere:Destroy() visualSphere = nil end
        for _, h in pairs(highlights) do h:Destroy() end
        highlights = {}
    end
end)

box.FocusLost:Connect(function()
    range = tonumber(box.Text) or 15
    box.Text = tostring(range)
end)

-- // ГЛАВНЫЙ ЦИКЛ (МАКСИМАЛЬНАЯ СКОРОСТЬ + РАДУГА)
local hue = 0
RunService.Heartbeat:Connect(function(dt)
    -- Анимация градиента заголовка
    hue = (hue + dt * 0.4) % 1
    tGrad.Rotation = (tGrad.Rotation + 2) % 360
    
